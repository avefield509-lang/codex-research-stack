{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marcus-ai4ss.github.io/VELA-Versioned-Evidence-Lifecycle-Architecture/imports/vela-helm-interface.schema.json",
  "title": "VELA HELM local import interface",
  "oneOf": [
    { "$ref": "#/$defs/velaProjectContext" },
    { "$ref": "#/$defs/helmCodexHandoff" }
  ],
  "$defs": {
    "pathMap": {
      "type": "object",
      "required": ["materials", "evidence", "claims", "methods", "deliverables", "handoffs"],
      "additionalProperties": false,
      "properties": {
        "materials": { "type": "string" },
        "evidence": { "type": "string" },
        "claims": { "type": "string" },
        "methods": { "type": "string" },
        "deliverables": { "type": "string" },
        "handoffs": { "type": "string" }
      }
    },
    "velaProjectContext": {
      "type": "object",
      "required": ["schema_version", "producer", "consumer", "project", "paths", "status", "evidence"],
      "additionalProperties": true,
      "properties": {
        "schema_version": { "const": "vela.project.context.v1" },
        "producer": { "const": "VELA" },
        "consumer": { "const": "HELM" },
        "project": {
          "type": "object",
          "required": ["id", "title", "root"],
          "additionalProperties": true,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "title": { "type": "string" },
            "root": { "type": "string" }
          }
        },
        "paths": { "$ref": "#/$defs/pathMap" },
        "status": {
          "type": "object",
          "required": ["phase", "blocked", "last_updated"],
          "additionalProperties": true,
          "properties": {
            "phase": { "type": "string" },
            "blocked": { "type": "boolean" },
            "last_updated": { "type": "string" }
          }
        },
        "evidence": {
          "type": "object",
          "required": ["items", "verified", "pending"],
          "additionalProperties": true,
          "properties": {
            "items": { "type": "integer", "minimum": 0 },
            "verified": { "type": "integer", "minimum": 0 },
            "pending": { "type": "integer", "minimum": 0 }
          }
        },
        "deliverables": { "type": "array" },
        "handoffs": { "type": "array" }
      }
    },
    "helmCodexHandoff": {
      "type": "object",
      "required": ["schema_version", "producer", "consumer", "project_id", "created_at", "codex_task"],
      "additionalProperties": true,
      "properties": {
        "schema_version": { "const": "helm.codex.handoff.v1" },
        "producer": { "const": "HELM" },
        "consumer": { "const": "VELA" },
        "project_id": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string" },
        "codex_task": {
          "type": "object",
          "required": ["task", "relevant_files", "constraints", "expected_output", "known_gaps", "review_standard"],
          "additionalProperties": true,
          "properties": {
            "task": { "type": "string", "minLength": 1 },
            "relevant_files": { "type": "array", "items": { "type": "string" } },
            "constraints": { "type": "array", "items": { "type": "string" } },
            "expected_output": { "type": "string" },
            "known_gaps": { "type": "array", "items": { "type": "string" } },
            "review_standard": { "type": "string" }
          }
        }
      }
    }
  }
}

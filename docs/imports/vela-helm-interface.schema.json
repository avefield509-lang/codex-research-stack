{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marcus-ai4ss.github.io/VELA/imports/vela-helm-interface.schema.json",
  "title": "VELA HELM local import interface",
  "oneOf": [
    { "$ref": "#/$defs/velaProjectContext" },
    { "$ref": "#/$defs/helmCodexHandoff" }
  ],
  "$defs": {
    "velaProjectContext": {
      "type": "object",
      "required": ["schema_version", "generated_at", "project", "paths", "truth_files", "counts", "quality", "helm"],
      "additionalProperties": true,
      "properties": {
        "schema_version": { "const": "vela.project.context.v1" },
        "producer": { "const": "VELA" },
        "consumer": { "const": "HELM" },
        "generated_at": { "type": "string" },
        "project": {
          "type": "object",
          "required": ["id", "name", "root", "stage", "status"],
          "additionalProperties": true,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "name": { "type": "string" },
            "title": { "type": "string" },
            "root": { "type": "string" },
            "stage": { "type": "string" },
            "status": { "type": "string" }
          }
        },
        "paths": {
          "type": "object",
          "required": ["materials", "evidence", "claims", "methods", "deliverables", "handoffs", "handoffs_helm", "logs"],
          "additionalProperties": true,
          "properties": {
            "materials": { "type": "string" },
            "evidence": { "type": "string" },
            "claims": { "type": "string" },
            "methods": { "type": "string" },
            "deliverables": { "type": "string" },
            "handoffs": { "type": "string" },
            "handoffs_helm": { "type": "string" },
            "logs": { "type": "string" }
          }
        },
        "truth_files": { "type": "array" },
        "counts": { "type": "object" },
        "quality": { "type": "object" },
        "helm": {
          "type": "object",
          "required": ["import_ready", "handoff_dir"],
          "additionalProperties": true,
          "properties": {
            "import_ready": { "type": "boolean" },
            "handoff_dir": { "type": "string" },
            "handoff_policy": { "enum": ["explicit_user_export_only", "copy_only_by_default"] }
          }
        }
      }
    },
    "helmCodexHandoff": {
      "type": "object",
      "required": ["schema_version", "generated_at", "project", "recommended_action", "relevant_files", "constraints", "missing_inputs", "validation_context", "human_review_required", "text"],
      "additionalProperties": true,
      "properties": {
        "schema_version": { "const": "helm.codex.handoff.v1" },
        "producer": { "const": "HELM" },
        "consumer": { "const": "VELA" },
        "generated_at": { "type": "string" },
        "project": { "type": "object" },
        "recommended_action": { "type": "string" },
        "relevant_files": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "missing_inputs": { "type": "array", "items": { "type": "string" } },
        "validation_context": { "type": "object" },
        "human_review_required": { "type": "boolean" },
        "text": { "type": "string" }
      }
    }
  }
}

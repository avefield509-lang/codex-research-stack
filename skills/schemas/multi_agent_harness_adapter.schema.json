{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-environment-local/schemas/multi_agent_harness_adapter.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "adapter_name",
    "status",
    "active_runtime",
    "future_targets",
    "activation_policy",
    "reads",
    "reserved_writes",
    "must_not_mutate",
    "bridge_rules",
    "checkpoint_contract"
  ],
  "properties": {
    "adapter_name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "reserved_interface_only"
      ]
    },
    "active_runtime": {
      "type": "boolean",
      "const": false
    },
    "future_targets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "activation_policy": {
      "type": "string",
      "minLength": 1
    },
    "reads": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "optional"
      ],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "reserved_writes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "minProperties": 1
    },
    "must_not_mutate": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "bridge_rules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "checkpoint_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_fields",
        "allowed_status"
      ],
      "properties": {
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "allowed_status": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  }
}

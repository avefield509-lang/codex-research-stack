{
  "clarification_card_fields": [
    "route_id",
    "target_item_count",
    "work_units",
    "deliverable_types",
    "sync_targets",
    "explicit_project_mode",
    "needs_clarification"
  ],
  "enums": {
    "work_units": [
      "discovery",
      "capture",
      "cleaning",
      "coding",
      "analysis",
      "writing",
      "review",
      "export",
      "reproducibility",
      "knowledge_sync"
    ],
    "deliverable_types": [
      "annotated_bibliography",
      "literature_synthesis",
      "case_dataset",
      "comment_analysis_report",
      "project_map",
      "paper_draft",
      "revision_package",
      "submission_package",
      "figures_tables",
      "reproducibility_bundle",
      "docx_export",
      "latex_export"
    ],
    "sync_targets": [
      "zotero",
      "obsidian"
    ],
    "explicit_project_mode": [
      "auto",
      "force_multi_agent",
      "force_single_agent"
    ],
    "required_review_for": [
      "paper_draft",
      "revision_package",
      "submission_package",
      "figures_tables",
      "reproducibility_bundle",
      "literature_synthesis",
      "case_dataset",
      "project_map"
    ]
  },
  "route_scope": {
    "always_multi_agent": [
      "computational-social-science",
      "social-science-submission-package",
      "project-retrospective"
    ],
    "never_default_multi_agent": [
      "stack-governance",
      "environment-ops",
      "single-paper-review",
      "long-running-experiment-ops"
    ],
    "conditional_multi_agent": [
      "literature-review",
      "social-platform-case",
      "writing-export",
      "empirical-quant",
      "text-corpus",
      "network-analysis",
      "general-research"
    ]
  },
  "input_priority": [
    "user_explicit_requirement",
    "clarification_card",
    "confirmed_thread_facts",
    "needs_clarification"
  ],
  "override_rules": {
    "force_single_agent": "single-producer-only-but-mandatory-review-still-applies",
    "force_multi_agent": "upgrade-to-sequential-multi-agent-execution",
    "auto": "route-defaults-and-conditional-rules"
  },
  "conditional_rules": {
    "literature-review": {
      "any": [
        {
          "field": "target_item_count",
          "operator": ">=",
          "value": 15
        },
        {
          "field": "deliverable_types",
          "operator": "contains",
          "value": "literature_synthesis"
        },
        {
          "field": "sync_targets",
          "operator": "contains_all",
          "value": [
            "zotero",
            "obsidian"
          ]
        }
      ]
    },
    "social-platform-case": {
      "any": [
        {
          "field": "target_item_count",
          "operator": ">",
          "value": 3
        },
        {
          "field": "deliverable_types",
          "operator": "contains_any",
          "value": [
            "case_dataset",
            "comment_analysis_report"
          ]
        },
        {
          "field": "work_units",
          "operator": "contains_all",
          "value": [
            "capture",
            "analysis"
          ]
        }
      ]
    },
    "writing-export": {
      "any": [
        {
          "field": "deliverable_types",
          "operator": "contains_any",
          "value": [
            "paper_draft",
            "revision_package",
            "submission_package"
          ]
        },
        {
          "field": "work_units",
          "operator": "contains_all",
          "value": [
            "writing",
            "review"
          ]
        }
      ],
      "single_agent_only_deliverables": [
        "docx_export",
        "latex_export"
      ]
    },
    "empirical-quant": {
      "any": [
        {
          "field": "work_units",
          "operator": "min_count",
          "value": 2,
          "pool": [
            "capture",
            "cleaning",
            "coding",
            "analysis",
            "writing",
            "reproducibility",
            "knowledge_sync"
          ]
        },
        {
          "field": "deliverable_types",
          "operator": "contains",
          "value": "figures_tables"
        },
        {
          "field": "deliverable_types",
          "operator": "contains_any",
          "value": [
            "reproducibility_bundle",
            "paper_draft",
            "literature_synthesis"
          ]
        }
      ],
      "all": [
        {
          "field": "deliverable_types",
          "operator": "contains",
          "value": "figures_tables"
        },
        {
          "field": "deliverable_types",
          "operator": "contains_any",
          "value": [
            "reproducibility_bundle",
            "paper_draft",
            "literature_synthesis"
          ]
        }
      ]
    },
    "text-corpus": {
      "copy_of": "empirical-quant"
    },
    "network-analysis": {
      "copy_of": "empirical-quant"
    },
    "general-research": {
      "requires_clarification_card": true
    }
  }
}

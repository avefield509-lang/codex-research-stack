{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marcus-ai4ss.github.io/VELA/schemas/vela.project.initializer.v1.schema.json",
  "title": "VELA Project Initializer Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "generated_at",
    "directories",
    "files",
    "project_agents"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "vela.project.initializer.v1"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "directories": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/file_entry"
      }
    },
    "project_agents": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    }
  },
  "$defs": {
    "file_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind",
        "content"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "text",
            "json"
          ]
        },
        "content": {}
      }
    }
  }
}
